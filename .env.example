# --- LLM provider -------------------------------------------------
# Leave empty to run in MOCK mode (scripted agent, no API calls).
# Paste your Vultr Serverless Inference key to go live.
VULTR_INFERENCE_API_KEY=

# Optional overrides (defaults in src/config/app.config.ts)
# LLM_PROVIDER=vultr            # 'vultr' | 'mock' (auto: vultr if key present)
# VULTR_INFERENCE_BASE_URL=https://api.vultrinference.com/v1
# VULTR_MODEL=kimi-k2-instruct
